{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/fetch_emails",
      "dest": "/api/fetch_emails.py"
    },
    {
      "src": "/predict_intent",
      "dest": "/api/predict_intent.py"
    },
    {
      "src": "/analytics",
      "dest": "/api/analytics.py"
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
